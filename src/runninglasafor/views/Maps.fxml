<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane styleClass="auth-scroll" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="runninglasafor.controllers.MapsController">
    <content>
        <VBox fx:id="rootBox" styleClass="content-area" spacing="20.0">
            <padding>
                <Insets top="24.0" right="28.0" bottom="24.0" left="28.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0">
                    <children>
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="page-title" text="%maps.title" />
                                <Label styleClass="page-subtitle" text="%maps.subtitle" />
                            </children>
                        </VBox>
                        <Button styleClass="primary-button" text="%maps.add" onAction="#onAdd">
                            <graphic>
                                <Region style="-fx-background-color: #FCFAFA; -fx-shape: 'M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z'; -fx-min-width: 14; -fx-min-height: 14;" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>

                <VBox styleClass="panel-card" spacing="10.0">
                    <padding>
                        <Insets top="18.0" right="18.0" bottom="18.0" left="18.0" />
                    </padding>
                    <children>
                        <Label styleClass="panel-title" text="%maps.registered" />
                        <ListView fx:id="mapsList" prefHeight="420.0" styleClass="activity-list" VBox.vgrow="ALWAYS" />
                        <Label fx:id="statusLabel" styleClass="status-label" wrapText="true" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
