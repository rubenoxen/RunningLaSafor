<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_LEFT" maxWidth="520.0" prefWidth="520.0" spacing="16.0"
      styleClass="content-area"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="runninglasafor.controllers.AddMapController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <Label styleClass="page-title" text="%addmap.title" />
        <Label styleClass="page-subtitle" text="%addmap.subtitle" wrapText="true" />

        <GridPane hgap="12.0" vgap="12.0">
            <columnConstraints>
                <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" minWidth="140.0" prefWidth="140.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label styleClass="form-label" text="%addmap.name" />
                <TextField fx:id="nameField" styleClass="form-input" promptText="%addmap.namePrompt" GridPane.columnIndex="1" />

                <Label styleClass="form-label" text="%addmap.image" GridPane.rowIndex="1" />
                <HBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <children>
                        <TextField fx:id="imagePathField" styleClass="form-input" promptText="%addmap.imagePrompt" HBox.hgrow="ALWAYS" />
                        <Button fx:id="browseButton" mnemonicParsing="false" onAction="#onBrowse" styleClass="secondary-button" text="%addmap.browse" />
                    </children>
                </HBox>

                <Label styleClass="form-label" text="%addmap.latMin" GridPane.rowIndex="2" />
                <TextField fx:id="latMinField" styleClass="form-input" promptText="%addmap.latMinPrompt" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label styleClass="form-label" text="%addmap.latMax" GridPane.rowIndex="3" />
                <TextField fx:id="latMaxField" styleClass="form-input" promptText="%addmap.latMaxPrompt" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label styleClass="form-label" text="%addmap.lonMin" GridPane.rowIndex="4" />
                <TextField fx:id="lonMinField" styleClass="form-input" promptText="%addmap.lonMinPrompt" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <Label styleClass="form-label" text="%addmap.lonMax" GridPane.rowIndex="5" />
                <TextField fx:id="lonMaxField" styleClass="form-input" promptText="%addmap.lonMaxPrompt" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            </children>
        </GridPane>

        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" />

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="cancelButton" cancelButton="true" mnemonicParsing="false" onAction="#onCancel" styleClass="secondary-button" text="%addmap.cancel" />
                <Button fx:id="acceptButton" defaultButton="true" mnemonicParsing="false" onAction="#onAccept" styleClass="primary-button" text="%addmap.accept" />
            </children>
        </HBox>
    </children>
</VBox>
