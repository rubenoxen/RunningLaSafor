<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane styleClass="auth-scroll"
            hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED"
            fitToWidth="true" fitToHeight="true"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="runninglasafor.controllers.ActivitiesListController">
    <content>
<HBox fx:id="authRoot" styleClass="auth-root" prefHeight="540.0" prefWidth="900.0">
    <children>
        <VBox styleClass="auth-form-panel" HBox.hgrow="ALWAYS" minWidth="420.0" spacing="14.0" alignment="TOP_LEFT">
            <padding>
                <Insets top="32.0" right="40.0" bottom="28.0" left="40.0" />
            </padding>
            <children>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <ImageView fx:id="brandLogo" styleClass="brand-logo" fitHeight="42.0" preserveRatio="true">
                            <image>
                                <Image url="@../../resources/logo_brand.png" />
                            </image>
                        </ImageView>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="themeButton" styleClass="theme-toggle" onAction="#onToggleTheme">
                            <graphic>
                                <Region fx:id="themeIcon" styleClass="theme-icon" />
                            </graphic>
                        </Button>
                        <ComboBox fx:id="languageBox" styleClass="lang-combo" />
                    </children>
                </HBox>

                <VBox spacing="4.0">
                    <children>
                        <Label styleClass="auth-title" text="%activities.title" wrapText="true" />
                        <Label styleClass="auth-subtitle" text="%activities.subtitle" wrapText="true" />
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="8.0">
                    <children>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button styleClass="secondary-button" text="%activities.refresh" onAction="#onRefresh" />
                    </children>
                </HBox>

                <ListView fx:id="activitiesList" styleClass="activity-list" prefHeight="300.0" VBox.vgrow="ALWAYS" />

                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Button styleClass="primary-button" text="%activities.import" onAction="#onImport" defaultButton="true" />
                        <Region HBox.hgrow="ALWAYS" />
                        <MenuButton fx:id="optionsButton" styleClass="options-button" text="%activities.options" disable="true">
                            <items>
                                <MenuItem text="%activities.view" onAction="#onView" />
                                <MenuItem text="%activities.rename" onAction="#onRename" />
                                <MenuItem text="%activities.delete" onAction="#onDelete" />
                            </items>
                        </MenuButton>
                    </children>
                </HBox>

                <Label fx:id="statusLabel" styleClass="status-label" wrapText="true" />
            </children>
        </VBox>

        <VBox styleClass="auth-image-panel" prefWidth="380.0" minWidth="320.0" alignment="TOP_LEFT" spacing="14.0">
            <padding>
                <Insets top="32.0" right="24.0" bottom="32.0" left="24.0" />
            </padding>
            <children>
                <VBox alignment="TOP_LEFT" spacing="4.0">
                    <children>
                        <Label styleClass="image-panel-title" text="%acc.title" wrapText="true" />
                        <Label styleClass="image-panel-sub" text="%acc.tagline.sub" wrapText="true" />
                    </children>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <children>
                        <Label styleClass="image-panel-label" text="%acc.period" />
                        <ComboBox fx:id="periodCombo" styleClass="form-combo" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    </children>
                </HBox>

                <VBox spacing="8.0">
                    <children>
                        <VBox styleClass="stat-card" spacing="2.0">
                            <padding>
                                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0" />
                            </padding>
                            <children>
                                <Label styleClass="stat-card-label" text="%acc.activities" />
                                <Label fx:id="lblCount" styleClass="stat-card-value" text="0" />
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="2.0">
                            <padding>
                                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0" />
                            </padding>
                            <children>
                                <Label styleClass="stat-card-label" text="%acc.distance" />
                                <Label fx:id="lblDistance" styleClass="stat-card-value" text="0 km" />
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="2.0">
                            <padding>
                                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0" />
                            </padding>
                            <children>
                                <Label styleClass="stat-card-label" text="%acc.time" />
                                <Label fx:id="lblTime" styleClass="stat-card-value" text="0h 00min" />
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="2.0">
                            <padding>
                                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0" />
                            </padding>
                            <children>
                                <Label styleClass="stat-card-label" text="%acc.speed" />
                                <Label fx:id="lblSpeed" styleClass="stat-card-value" text="0 km/h" />
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="2.0">
                            <padding>
                                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0" />
                            </padding>
                            <children>
                                <Label styleClass="stat-card-label" text="%acc.gain" />
                                <Label fx:id="lblGain" styleClass="stat-card-value" text="0 m" />
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="2.0">
                            <padding>
                                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0" />
                            </padding>
                            <children>
                                <Label styleClass="stat-card-label" text="%acc.loss" />
                                <Label fx:id="lblLoss" styleClass="stat-card-value" text="0 m" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</HBox>
    </content>
</ScrollPane>
