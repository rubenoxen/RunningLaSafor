<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0"
      xmlns="http://javafx.com/javafx/23.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="runninglasafor.controllers.HistoryController">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label text="%history.title" style="-fx-font-size: 20; -fx-font-weight: bold;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="%history.refresh" onAction="#onRefresh" />
            </children>
        </HBox>

        <TableView fx:id="sessionsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colStart" text="%history.col.start" prefWidth="160.0" />
                <TableColumn fx:id="colEnd" text="%history.col.end" prefWidth="160.0" />
                <TableColumn fx:id="colDuration" text="%history.col.duration" prefWidth="100.0" />
                <TableColumn fx:id="colImports" text="%history.col.imports" prefWidth="100.0" />
                <TableColumn fx:id="colViews" text="%history.col.views" prefWidth="100.0" />
                <TableColumn fx:id="colAnnotations" text="%history.col.annotations" prefWidth="120.0" />
            </columns>
        </TableView>

        <Label fx:id="statusLabel" style="-fx-text-fill: #777;" />
    </children>
</VBox>
