<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="app-chrome" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="runninglasafor.controllers.MapViewController">
   <top>
      <HBox styleClass="auth-form-panel" alignment="CENTER_RIGHT" spacing="10.0" BorderPane.alignment="CENTER">
         <padding><Insets bottom="8.0" left="10.0" right="15.0" top="8.0" /></padding>
         <children>
            <Label text="%map.zoom" styleClass="form-label"/>
            <Button mnemonicParsing="false" onAction="#zoomOut" text="-" styleClass="secondary-button" />
            <Slider fx:id="zoomSlider" max="1.5" min="0.5" value="1.0" />
            <Button mnemonicParsing="false" onAction="#zoomIn" text="+" styleClass="secondary-button" />
         </children>
      </HBox>
   </top>
   <center>
      <ScrollPane fx:id="mapScrollPane" pannable="true" styleClass="map-scroll" BorderPane.alignment="CENTER">
         <content>
            <Group fx:id="zoomGroup">
               <children>
                  <Pane fx:id="mapPane">
                     <children>
                        <ImageView fx:id="mapImageView" pickOnBounds="true" preserveRatio="true" />
                     </children>
                  </Pane>
               </children>
            </Group>
         </content>
      </ScrollPane>
   </center>
</BorderPane>