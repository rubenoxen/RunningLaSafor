<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="panel-card" prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="runninglasafor.controllers.MapViewController">
    <padding>
        <Insets top="0.0" right="0.0" bottom="0.0" left="0.0" />
    </padding>
    <children>
        <BorderPane VBox.vgrow="ALWAYS">
            <top>
                <HBox alignment="CENTER_RIGHT" spacing="10.0" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="10.0" left="14.0" right="14.0" top="10.0" />
                    </padding>
                    <children>
                        <Label text="%map.zoom" styleClass="form-label" />
                        <Button mnemonicParsing="false" onAction="#zoomOut" text="-" styleClass="secondary-button" />
                        <Slider fx:id="zoomSlider" max="1.5" min="0.5" value="1.0" prefWidth="120" />
                        <Button mnemonicParsing="false" onAction="#zoomIn" text="+" styleClass="secondary-button" />
                        <Region HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            </top>
            <center>
                <ScrollPane fx:id="mapScrollPane" pannable="true" styleClass="map-scroll" BorderPane.alignment="CENTER">
                    <content>
                        <Group fx:id="zoomGroup">
                            <children>
                                <Pane fx:id="mapPane">
                                    <children>
                                        <ImageView fx:id="mapImageView" pickOnBounds="true" preserveRatio="true" />
                                    </children>
                                </Pane>
                            </children>
                        </Group>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>
    </children>
</VBox>
