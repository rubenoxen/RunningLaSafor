      </HBox>
   </top>
   <center>
      <SplitPane dividerPositions="0.5779569892473119" orientation="VERTICAL" style="-fx-background-color: transparent;" BorderPane.alignment="CENTER">
        <items>
            <fx:include fx:id="mapView" source="MapView.fxml" />
            <AnchorPane minHeight="0.0" minWidth="0.0" styleClass="app-chrome">
