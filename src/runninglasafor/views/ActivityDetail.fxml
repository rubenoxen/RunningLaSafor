<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane styleClass="auth-scroll" fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="runninglasafor.controllers.ActivityDetailController">
    <content>
        <VBox fx:id="detailRoot" styleClass="content-area" spacing="16.0">
            <padding>
                <Insets top="20.0" right="24.0" bottom="20.0" left="24.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0">
                    <children>
                        <Button fx:id="backButton" styleClass="back-button" text="←" onAction="#onBack" />
                        <Label styleClass="page-title" text="%detail.title" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label styleClass="form-label" text="%detail.map" />
                        <ComboBox fx:id="mapSelector" prefWidth="200.0" styleClass="form-combo" />
                        <Button fx:id="addMapButton" onAction="#onAddMap" styleClass="secondary-button" text="%detail.addMap" />
                    </children>
                </HBox>

                <HBox spacing="16.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox styleClass="panel-card" spacing="14.0" minWidth="340.0" maxWidth="400.0" HBox.hgrow="NEVER">
                            <padding>
                                <Insets top="18.0" right="18.0" bottom="18.0" left="18.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <StackPane style="-fx-background-color: #AF3B6E; -fx-background-radius: 20; -fx-min-width: 40; -fx-min-height: 40; -fx-max-width: 40; -fx-max-height: 40;">
                                            <children>
                                                <Region style="-fx-background-color: #FCFAFA; -fx-shape: 'M13.49 5.48c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm-3.6 13.9l1-4.4 2.1 2v6h2v-7.5l-2.1-2 .6-3c1.3 1.5 3.3 2.5 5.5 2.5v-2c-1.9 0-3.5-1-4.3-2.4l-1-1.6c-.4-.6-1-1-1.7-1-.3 0-.5.1-.8.1l-5.2 2.2v4.7h2v-3.4l1.8-.7-1.6 8.1-4.9-1-.4 2 7 1.4z'; -fx-min-width: 20; -fx-min-height: 20;" />
                                            </children>
                                        </StackPane>
                                        <VBox spacing="2.0">
                                            <children>
                                                <Label fx:id="activityNameLabel" styleClass="panel-title" text="%detail.activity" />
                                                <Label fx:id="activityDateLabel" styleClass="panel-subtitle" text="" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox styleClass="divider-h" />

                                <GridPane hgap="12.0" vgap="12.0">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="120.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="%detail.distance" styleClass="stat-card-label" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                        <Label fx:id="distanceLabel" styleClass="activity-name-label" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                                        <Label text="%detail.duration" styleClass="stat-card-label" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                        <Label fx:id="durationLabel" styleClass="activity-name-label" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                                        <Label text="%detail.pace" styleClass="stat-card-label" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                        <Label fx:id="paceLabel" styleClass="activity-name-label" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                                        <Label text="%detail.speed" styleClass="stat-card-label" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                        <Label fx:id="speedLabel" styleClass="activity-name-label" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                                        <Label text="%acc.gain" styleClass="stat-card-label" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                                        <Label fx:id="elevationLabel" styleClass="activity-name-label" text="-" GridPane.rowIndex="4" GridPane.columnIndex="1" />

                                        <Label text="%detail.minElev" styleClass="stat-card-label" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                                        <Label fx:id="minElevLabel" styleClass="activity-name-label" text="-" GridPane.rowIndex="5" GridPane.columnIndex="1" />

                                        <Label text="%detail.maxElev" styleClass="stat-card-label" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                                        <Label fx:id="maxElevLabel" styleClass="activity-name-label" text="-" GridPane.rowIndex="6" GridPane.columnIndex="1" />
                                    </children>
                                </GridPane>

                                <HBox styleClass="divider-h" />

                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label styleClass="panel-title" text="%detail.annotations" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button styleClass="secondary-button" text="%detail.viewAnnotations" onAction="#onViewAnnotations" />
                                    </children>
                                </HBox>
                                <Label fx:id="annotationsHint" styleClass="panel-subtitle" text="%detail.annotations.hint" wrapText="true" />
                            </children>
                        </VBox>

                        <VBox HBox.hgrow="ALWAYS" spacing="0.0">
                            <children>
                                <fx:include fx:id="mapView" source="MapView.fxml" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox styleClass="panel-card" spacing="12.0">
                    <padding>
                        <Insets top="16.0" right="18.0" bottom="16.0" left="18.0" />
                    </padding>
                    <children>
                        <TabPane fx:id="detailTabs" tabClosingPolicy="UNAVAILABLE">
                            <tabs>
                                <Tab text="%detail.tab.summary">
                                    <content>
                                        <VBox spacing="10.0">
                                            <padding>
                                                <Insets top="14.0" right="6.0" bottom="6.0" left="6.0" />
                                            </padding>
                                            <children>
                                                <GridPane hgap="14.0" vgap="14.0">
                                                    <columnConstraints>
                                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3" />
                                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3" />
                                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.4" />
                                                    </columnConstraints>
                                                    <children>
                                                        <VBox styleClass="stat-card" spacing="4.0" GridPane.rowIndex="0" GridPane.columnIndex="0">
                                                            <padding>
                                                                <Insets top="12.0" right="14.0" bottom="12.0" left="14.0" />
                                                            </padding>
                                                            <children>
                                                                <Label styleClass="stat-card-label" text="%detail.distance" />
                                                                <Label fx:id="summaryDistance" styleClass="stat-card-value" text="-" />
                                                            </children>
                                                        </VBox>
                                                        <VBox styleClass="stat-card" spacing="4.0" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                                            <padding>
                                                                <Insets top="12.0" right="14.0" bottom="12.0" left="14.0" />
                                                            </padding>
                                                            <children>
                                                                <Label styleClass="stat-card-label" text="%detail.duration" />
                                                                <Label fx:id="summaryDuration" styleClass="stat-card-value" text="-" />
                                                            </children>
                                                        </VBox>
                                                        <VBox styleClass="stat-card" spacing="4.0" GridPane.rowIndex="0" GridPane.columnIndex="2">
                                                            <padding>
                                                                <Insets top="12.0" right="14.0" bottom="12.0" left="14.0" />
                                                            </padding>
                                                            <children>
                                                                <Label styleClass="stat-card-label" text="%detail.pace" />
                                                                <Label fx:id="summaryPace" styleClass="stat-card-value" text="-" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </GridPane>
                                            </children>
                                        </VBox>
                                    </content>
                                </Tab>
                                <Tab text="%detail.tab.elevation">
                                    <content>
                                        <VBox spacing="4.0">
                                            <padding>
                                                <Insets top="12.0" right="6.0" bottom="6.0" left="6.0" />
                                            </padding>
                                            <children>
                                                <fx:include fx:id="elevationProfile" source="ElevationProfile.fxml" VBox.vgrow="ALWAYS" />
                                            </children>
                                        </VBox>
                                    </content>
                                </Tab>
                                <Tab text="%detail.tab.speed">
                                    <content>
                                        <VBox spacing="4.0">
                                            <padding>
                                                <Insets top="12.0" right="6.0" bottom="6.0" left="6.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="panel-subtitle" text="%detail.tab.speed.hint" wrapText="true" />
                                                <Region prefHeight="180" />
                                            </children>
                                        </VBox>
                                    </content>
                                </Tab>
                            </tabs>
                        </TabPane>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
