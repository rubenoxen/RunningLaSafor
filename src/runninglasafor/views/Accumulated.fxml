<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox fx:id="authRoot" styleClass="auth-root" prefHeight="540.0" prefWidth="900.0"
      xmlns="http://javafx.com/javafx/23.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="runninglasafor.controllers.AccumulatedController">
    <children>
        <VBox styleClass="auth-form-panel" HBox.hgrow="ALWAYS" minWidth="520.0" spacing="18.0" alignment="TOP_LEFT">
            <padding>
                <Insets top="32.0" right="40.0" bottom="28.0" left="40.0" />
            </padding>
            <children>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <ImageView fx:id="brandLogo" styleClass="brand-logo" fitHeight="42.0" preserveRatio="true">
                            <image>
                                <Image url="@../resources/logo_brand.png" />
                            </image>
                        </ImageView>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="themeButton" styleClass="theme-toggle" onAction="#onToggleTheme">
                            <graphic>
                                <Region fx:id="themeIcon" styleClass="theme-icon" />
                            </graphic>
                        </Button>
                        <ComboBox fx:id="languageBox" styleClass="lang-combo" />
                    </children>
                </HBox>

                <VBox spacing="4.0">
                    <children>
                        <Label styleClass="auth-title" text="%acc.title" wrapText="true" />
                        <Label styleClass="auth-subtitle" text="%acc.subtitle" wrapText="true" />
                    </children>
                </VBox>

                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label styleClass="form-label" text="%acc.period" />
                        <ComboBox fx:id="periodCombo" styleClass="form-combo" prefWidth="220.0" />
                    </children>
                </HBox>

                <GridPane hgap="12.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.4" />
                    </columnConstraints>
                    <children>
                        <VBox styleClass="stat-card" spacing="6.0"
                              GridPane.rowIndex="0" GridPane.columnIndex="0">
                            <padding>
                                <Insets bottom="14.0" left="16.0" right="16.0" top="14.0" />
                            </padding>
                            <children>
                                <Label styleClass="stat-card-label" text="%acc.activities" />
                                <Label fx:id="lblCount" styleClass="stat-card-value" text="0" />
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="6.0"
                              GridPane.rowIndex="0" GridPane.columnIndex="1">
                            <padding>
                                <Insets bottom="14.0" left="16.0" right="16.0" top="14.0" />
                            </padding>
                            <children>
                                <Label styleClass="stat-card-label" text="%acc.distance" />
                                <Label fx:id="lblDistance" styleClass="stat-card-value" text="0 km" />
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="6.0"
                              GridPane.rowIndex="0" GridPane.columnIndex="2">
                            <padding>
                                <Insets bottom="14.0" left="16.0" right="16.0" top="14.0" />
                            </padding>
                            <children>
                                <Label styleClass="stat-card-label" text="%acc.time" />
                                <Label fx:id="lblTime" styleClass="stat-card-value" text="0h" />
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="6.0"
                              GridPane.rowIndex="1" GridPane.columnIndex="0">
                            <padding>
                                <Insets bottom="14.0" left="16.0" right="16.0" top="14.0" />
                            </padding>
                            <children>
                                <Label styleClass="stat-card-label" text="%acc.gain" />
                                <Label fx:id="lblGain" styleClass="stat-card-value" text="0 m" />
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="6.0"
                              GridPane.rowIndex="1" GridPane.columnIndex="1">
                            <padding>
                                <Insets bottom="14.0" left="16.0" right="16.0" top="14.0" />
                            </padding>
                            <children>
                                <Label styleClass="stat-card-label" text="%acc.loss" />
                                <Label fx:id="lblLoss" styleClass="stat-card-value" text="0 m" />
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="6.0"
                              GridPane.rowIndex="1" GridPane.columnIndex="2">
                            <padding>
                                <Insets bottom="14.0" left="16.0" right="16.0" top="14.0" />
                            </padding>
                            <children>
                                <Label styleClass="stat-card-label" text="%acc.speed" />
                                <Label fx:id="lblSpeed" styleClass="stat-card-value" text="0 km/h" />
                            </children>
                        </VBox>
                    </children>
                </GridPane>

                <Label fx:id="statusLabel" styleClass="status-label" wrapText="true" />
            </children>
        </VBox>

        <VBox styleClass="auth-image-panel" prefWidth="320.0" minWidth="240.0" alignment="CENTER" spacing="10.0">
            <padding>
                <Insets top="32.0" right="28.0" bottom="32.0" left="28.0" />
            </padding>
            <children>
                <ImageView fx:id="bgImage" fitHeight="220.0" preserveRatio="true" opacity="0.65" blendMode="MULTIPLY">
                    <image>
                        <Image url="@../resources/running_bg.png" />
                    </image>
                </ImageView>
                <VBox alignment="CENTER" spacing="-4.0">
                    <children>
                        <Label styleClass="image-tagline-1" text="%acc.tagline1" />
                        <Label styleClass="image-tagline-2" text="%acc.tagline2" />
                    </children>
                </VBox>
                <Label styleClass="image-tagline-sub" text="%acc.tagline.sub" wrapText="true" />
            </children>
        </VBox>
    </children>
</HBox>