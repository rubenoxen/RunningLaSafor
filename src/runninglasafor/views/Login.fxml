<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/23.0.1"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="runninglasafor.controllers.LoginController">
    <children>
        <VBox alignment="CENTER" spacing="12.0" maxWidth="320.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="%login.title" style="-fx-font-size: 22; -fx-font-weight: bold;" />
                <Label text="%login.subtitle" style="-fx-text-fill: #777;" />
                <TextField fx:id="userField" promptText="%login.userPrompt" />
                <PasswordField fx:id="passField" promptText="%login.passwordPrompt" onAction="#onLogin" />
                <Label fx:id="errorLabel" style="-fx-text-fill: #c0392b;" wrapText="true" />
                <Button text="%login.button" onAction="#onLogin" maxWidth="Infinity" defaultButton="true" />
                <HBox alignment="CENTER" spacing="4.0">
                    <children>
                        <Label text="%login.noAccount" />
                        <Hyperlink text="%login.register" onAction="#onRegister" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
