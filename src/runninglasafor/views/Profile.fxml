<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<HBox fx:id="authRoot" styleClass="auth-root" prefHeight="540.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="runninglasafor.controllers.ProfileController">
    <children>
        <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS" styleClass="auth-scroll">
            <content>
                <VBox spacing="14.0" maxWidth="640.0" styleClass="auth-form-panel">
                    <padding>
                        <Insets bottom="20.0" left="40.0" right="40.0" top="32.0" />
                    </padding>
                    <children>
                        <Label text="%profile.title" styleClass="auth-title" />
                        <Label text="%profile.subtitle" styleClass="auth-subtitle" wrapText="true" />
                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                            <children>
                                <ImageView fx:id="avatarPreview" fitWidth="80.0" fitHeight="80.0" preserveRatio="true" />
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="nickLabel" styleClass="form-label" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                                        <Label fx:id="emailReadLabel" styleClass="auth-subtitle" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <GridPane hgap="10.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="120.0" prefWidth="150.0" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <children>
                                <Label text="%profile.email" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                <TextField fx:id="emailField" styleClass="form-input" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                                <Label text="%profile.birth" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                <DatePicker fx:id="birthPicker" styleClass="form-input" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                                <Label text="%profile.avatar" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                <HBox spacing="6.0" GridPane.rowIndex="2" GridPane.columnIndex="1">
                                    <children>
                                        <TextField fx:id="avatarField" styleClass="form-input" HBox.hgrow="ALWAYS" />
                                        <Button text="%profile.browse" styleClass="secondary-button" onAction="#onBrowseAvatar" />
                                    </children>
                                </HBox>
                                <Label text="%profile.password" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                <PasswordField fx:id="passField" styleClass="form-input" promptText="%profile.passwordHint" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                                <Label text="%profile.confirm" styleClass="form-label" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                                <PasswordField fx:id="confirmField" styleClass="form-input" GridPane.rowIndex="4" GridPane.columnIndex="1" />
                            </children>
                        </GridPane>
                        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" />
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <children>
                                <Button text="%profile.logout" styleClass="secondary-button" onAction="#onLogout" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button text="%profile.back" styleClass="secondary-button" onAction="#onBack" />
                                <Button text="%profile.save" styleClass="primary-button" onAction="#onSave" defaultButton="true" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</HBox>