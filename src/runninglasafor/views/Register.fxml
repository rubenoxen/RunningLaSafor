<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/23.0.1"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="runninglasafor.controllers.RegisterController">
    <children>
        <VBox alignment="CENTER" spacing="12.0" maxWidth="420.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="Crear cuenta" style="-fx-font-size: 22; -fx-font-weight: bold;" />
                <Label text="Todos los campos marcados son obligatorios." style="-fx-text-fill: #777;" />

                <GridPane hgap="10.0" vgap="8.0">
                    <columnConstraints>
                        <javafx.scene.layout.ColumnConstraints minWidth="110.0" />
                        <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <children>
                        <Label text="Usuario *" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <TextField fx:id="nickField" promptText="Nombre de usuario"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1" />

                        <Label text="Email *" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <TextField fx:id="emailField" promptText="ejemplo@dominio.com"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1" />

                        <Label text="Contrasena *" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <PasswordField fx:id="passField" promptText="Contrasena"
                                       GridPane.rowIndex="2" GridPane.columnIndex="1" />

                        <Label text="Repetir *" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                        <PasswordField fx:id="confirmField" promptText="Repite la contrasena"
                                       GridPane.rowIndex="3" GridPane.columnIndex="1" />

                        <Label text="Fecha nac. *" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                        <DatePicker fx:id="birthPicker" maxWidth="Infinity"
                                    GridPane.rowIndex="4" GridPane.columnIndex="1" />

                        <Label text="Avatar" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                        <HBox spacing="6.0" GridPane.rowIndex="5" GridPane.columnIndex="1">
                            <children>
                                <TextField fx:id="avatarField" promptText="Ruta de la imagen"
                                           HBox.hgrow="ALWAYS" />
                                <Button text="Examinar..." onAction="#onBrowseAvatar" />
                            </children>
                        </HBox>
                    </children>
                </GridPane>

                <Label fx:id="errorLabel" style="-fx-text-fill: #c0392b;" wrapText="true" />

                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button text="Crear cuenta" onAction="#onCreate" defaultButton="true" />
                        <Hyperlink text="Volver al inicio de sesion" onAction="#onBack" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
